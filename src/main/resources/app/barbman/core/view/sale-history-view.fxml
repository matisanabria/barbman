<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.barbman.core.controller.sales.SalesHistoryController"
            styleClass="history-root"
            prefWidth="1000"
            prefHeight="700">

    <!-- TOP - HEADER & FILTERS -->
    <top>
        <VBox spacing="16" styleClass="history-header">
            <padding>
                <Insets top="20" right="24" bottom="20" left="24"/>
            </padding>

            <!-- Title -->
            <Label text="📜 Historial de Ventas" styleClass="history-title"/>

            <!-- Filters -->
            <HBox spacing="16" alignment="CENTER_LEFT">

                <Label text="Desde:" styleClass="history-filter-label"/>
                <DatePicker fx:id="dateFromPicker"
                            styleClass="history-datepicker"
                            prefWidth="150"/>

                <Label text="Hasta:" styleClass="history-filter-label"/>
                <DatePicker fx:id="dateToPicker"
                            styleClass="history-datepicker"
                            prefWidth="150"/>

                <Button fx:id="btnFilter"
                        text="🔍 Filtrar"
                        styleClass="history-btn-filter"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button fx:id="btnDelete"
                        text="Eliminar"
                        styleClass="history-btn-delete"
                        visible="false"/>

            </HBox>

            <Label text="💡 Doble clic en una venta para ver el detalle completo"
                   styleClass="history-hint"/>

        </VBox>
    </top>

    <!-- CENTER - TABLE -->
    <center>
        <TableView fx:id="salesTable"
                   styleClass="history-table">
            <columns>
                <TableColumn fx:id="colDate"
                             text="Fecha"
                             prefWidth="120"
                             styleClass="history-column"/>

                <TableColumn fx:id="colUser"
                             text="Usuario"
                             prefWidth="150"
                             styleClass="history-column"/>

                <TableColumn fx:id="colClient"
                             text="Cliente"
                             prefWidth="200"
                             styleClass="history-column"/>

                <TableColumn fx:id="colTotal"
                             text="Total"
                             prefWidth="150"
                             styleClass="history-column"/>

                <TableColumn fx:id="colPaymentMethod"
                             text="Método de Pago"
                             prefWidth="180"
                             styleClass="history-column"/>
            </columns>

            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </center>

</BorderPane>