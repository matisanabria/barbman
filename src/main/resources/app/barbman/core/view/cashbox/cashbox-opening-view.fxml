<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700"
            prefWidth="560"
            styleClass="cashbox-root"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.barbman.core.controller.cashbox.CashboxOpeningController">

    <!-- TOP - HEADER -->
    <top>
        <VBox alignment="CENTER"
              spacing="6"
              styleClass="cashbox-hero">
            <padding>
                <Insets top="20" bottom="16"/>
            </padding>

            <Label text="APERTURA DE CAJA"
                   styleClass="cashbox-hero-title"/>

            <HBox alignment="CENTER" spacing="6">
                <Label text="📅" styleClass="period-icon"/>
                <Label fx:id="periodLabel"
                       text="Período: Lunes 13/01/2026"
                       styleClass="cashbox-hero-subtitle"/>
            </HBox>
        </VBox>
    </top>

    <!-- CENTER - FORM -->
    <center>
        <ScrollPane fitToWidth="true"
                    styleClass="cashbox-scroll">
            <VBox spacing="20"
                  styleClass="cashbox-form">
                <padding>
                    <Insets top="20" right="40" bottom="20" left="40"/>
                </padding>

                <!-- EFECTIVO -->
                <VBox spacing="10" styleClass="amount-card">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="💵" styleClass="card-icon"/>
                        <Label text="EFECTIVO" styleClass="card-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="previousCashLabel"
                               text="Anterior: 0 Gs"
                               styleClass="card-hint"/>
                    </HBox>

                    <TextField fx:id="cashField"
                               promptText="0"
                               alignment="CENTER"
                               styleClass="amount-input"
                               style="-fx-background-color: #2A2A2A; -fx-background-radius: 12; -fx-text-fill: #F0C667; -fx-font-size: 24px; -fx-font-weight: bold; -fx-prompt-text-fill: #666666; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;"/>

                    <Label text="💡 Dinero físico en billetes y monedas"
                           styleClass="field-hint"/>
                </VBox>

                <!-- BANCO -->
                <VBox spacing="10" styleClass="amount-card">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="🏦" styleClass="card-icon"/>
                        <Label text="BANCO" styleClass="card-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="previousBankLabel"
                               text="Anterior: 0 Gs"
                               styleClass="card-hint"/>
                    </HBox>

                    <TextField fx:id="bankField"
                               promptText="0"
                               alignment="CENTER"
                               styleClass="amount-input"
                               style="-fx-background-color: #2A2A2A; -fx-background-radius: 12; -fx-text-fill: #F0C667; -fx-font-size: 24px; -fx-font-weight: bold; -fx-prompt-text-fill: #666666; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;"/>

                    <Label text="💡 Transferencias + Tarjeta + QR"
                           styleClass="field-hint"/>
                </VBox>

                <!-- TOTAL PREVIEW -->
                <HBox alignment="CENTER"
                      spacing="16"
                      styleClass="total-preview">
                    <padding>
                        <Insets top="14" bottom="14"/>
                    </padding>

                    <VBox alignment="CENTER" spacing="4">
                        <Label text="TOTAL APERTURA"
                               styleClass="total-label"/>
                        <Label fx:id="totalOpeningLabel"
                               text="0 Gs"
                               styleClass="total-value"/>
                    </VBox>

                    <Separator orientation="VERTICAL" styleClass="total-separator"/>

                    <VBox alignment="CENTER" spacing="4">
                        <Label text="ANTERIOR"
                               styleClass="total-label-secondary"/>
                        <Label fx:id="previousTotalLabel"
                               text="0 Gs"
                               styleClass="total-value-secondary"/>
                    </VBox>
                </HBox>

                <!-- NOTAS -->
                <VBox spacing="10" styleClass="notes-section">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="📝" styleClass="notes-icon"/>
                        <Label text="Notas (opcional)"
                               styleClass="notes-title"/>
                    </HBox>

                    <TextArea fx:id="notesArea"
                              promptText="Algún detalle importante..."
                              prefRowCount="2"
                              wrapText="true"
                              styleClass="notes-textarea"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- BOTTOM - FOOTER -->
    <bottom>
        <VBox spacing="0" styleClass="cashbox-footer-section">

            <!-- Info bar -->
            <HBox alignment="CENTER_LEFT"
                  spacing="20"
                  styleClass="info-bar">
                <padding>
                    <Insets top="12" right="40" bottom="12" left="40"/>
                </padding>

                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="👤" styleClass="info-icon"/>
                    <Label fx:id="openedByLabel"
                           text="Usuario: ADMIN"
                           styleClass="info-text"/>
                </HBox>

                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="🕐" styleClass="info-icon"/>
                    <Label fx:id="openedAtLabel"
                           text="08:02"
                           styleClass="info-text"/>
                </HBox>
            </HBox>

            <!-- Action buttons -->
            <HBox alignment="CENTER_RIGHT"
                  spacing="12"
                  styleClass="action-bar">
                <padding>
                    <Insets top="16" right="40" bottom="18" left="40"/>
                </padding>

                <Button onAction="#onCancel"
                        text="Cancelar"
                        styleClass="btn-cancel"/>

                <Button onAction="#onOpenCashbox"
                        text="✅ ABRIR CAJA"
                        styleClass="btn-confirm"/>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>