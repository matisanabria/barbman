<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<AnchorPane
xmlns="http://javafx.com/javafx"
xmlns:fx="http://javafx.com/fxml"
prefWidth="520"
prefHeight="620"
styleClass="cashbox-root">

<VBox
        layoutX="0"
        layoutY="0"
        prefWidth="520"
        prefHeight="620"
        spacing="18"
        alignment="TOP_CENTER"
        AnchorPane.topAnchor="0"
        AnchorPane.bottomAnchor="0"
        AnchorPane.leftAnchor="0"
        AnchorPane.rightAnchor="0">
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- TITLE -->
    <Label
            text="OPEN CASHBOX"
            prefWidth="460"
            alignment="CENTER"
            styleClass="cashbox-title"/>

    <!-- PERIOD -->
    <Label
            text="Period start: MONDAY 2026-01-13"
            prefWidth="460"
            alignment="CENTER"
            styleClass="cashbox-subtitle"/>

    <Separator prefWidth="460"/>

    <!-- CASH -->
    <VBox spacing="6" prefWidth="460">
        <Label text="CASH AMOUNT" styleClass="cashbox-label"/>
        <TextField
                prefWidth="460"
                prefHeight="42"
                text="0.00"
                styleClass="cashbox-input"/>
        <Label
                text="Suggested from last closure: 0.00"
                styleClass="cashbox-hint"/>
    </VBox>

    <!-- BANK -->
    <VBox spacing="6" prefWidth="460">
        <Label text="BANK AMOUNT" styleClass="cashbox-label"/>
        <TextField
                prefWidth="460"
                prefHeight="42"
                text="0.00"
                styleClass="cashbox-input"/>
        <Label
                text="Transfers + Card + QR"
                styleClass="cashbox-hint"/>
    </VBox>

    <!-- NOTES -->
    <VBox spacing="6" prefWidth="460">
        <Label text="NOTES (optional)" styleClass="cashbox-label"/>
        <TextArea
                prefWidth="460"
                prefHeight="90"
                wrapText="true"
                styleClass="cashbox-textarea"/>
    </VBox>

    <Separator prefWidth="460"/>

    <!-- FOOTER INFO -->
    <VBox spacing="4" prefWidth="460">
        <Label text="Opened by: ADMIN USER" styleClass="cashbox-footer"/>
        <Label text="Opened at: 08:02" styleClass="cashbox-footer"/>
    </VBox>

    <!-- ACTIONS -->
    <HBox
            prefWidth="460"
            spacing="16"
            alignment="CENTER_RIGHT">

        <Button
                text="CANCEL"
                prefWidth="120"
                prefHeight="40"
                styleClass="cashbox-btn-secondary"/>

        <Button
                text="OPEN CASHBOX"
                prefWidth="180"
                prefHeight="40"
                styleClass="cashbox-btn-primary"/>
    </HBox>

</VBox>
</AnchorPane>
