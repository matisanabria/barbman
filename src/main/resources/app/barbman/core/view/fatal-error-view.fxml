<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="500" prefWidth="700" styleClass="fatal-error-root" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.barbman.core.controller.FatalErrorController">

    <top>
        <VBox spacing="12" styleClass="fatal-error-header">
            <padding>
                <Insets bottom="24" left="24" right="24" top="24" />
            </padding>

            <!-- Error icon and title -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label styleClass="error-icon" />
                <Label fx:id="errorTitleLabel" styleClass="error-title" text="Error crítico" />
            </HBox>

            <!-- Error message -->
            <Label styleClass="error-message" text="Ha ocurrido un error inesperado. Copie el error y envialo al desarrollador" wrapText="true" />
         <Label fx:id="errorMessageLabel" layoutX="34.0" layoutY="63.0" styleClass="error-message" text="Ha ocurrido un error inesperado. Copie el error y envialo al desarrollador" wrapText="true" />
        </VBox>
    </top>

    <center>
        <VBox spacing="12" styleClass="fatal-error-content">
            <padding>
                <Insets bottom="12" left="24" right="24" top="12" />
            </padding>

            <Label styleClass="section-label" text="Detalles técnicos:" />

            <TextArea fx:id="stackTraceArea" editable="false" styleClass="stack-trace-area" wrapText="false" VBox.vgrow="ALWAYS" />
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="12" styleClass="fatal-error-footer">
            <padding>
                <Insets bottom="24" left="24" right="24" top="16" />
            </padding>

            <Button fx:id="copyButton" styleClass="copy-button" text="📋 Copiar error" />

            <Button fx:id="closeButton" styleClass="close-button" text="Cerrar aplicación" />
        </HBox>
    </bottom>

</BorderPane>
