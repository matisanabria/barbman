<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<AnchorPane prefHeight="720" prefWidth="1280.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.barbman.core.controller.MainViewController">
    <children>
        <BorderPane fx:id="borderPane"
                    prefHeight="632.0"
                    prefWidth="1016.0"
                    AnchorPane.bottomAnchor="4.0"
                    AnchorPane.leftAnchor="4.0"
                    AnchorPane.rightAnchor="4.0"
                    AnchorPane.topAnchor="4.0"
                    styleClass="main-borderpane">
            <left>
                <!-- Este espacio será reemplazado dinámicamente -->
                <VBox fx:id="sidebarPlaceholder" minWidth="250"/>
            </left>
            <center>
                <StackPane fx:id="centerPane"/>
            </center>

        </BorderPane>
    </children>
</AnchorPane>
