<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane fitToWidth="true" pannable="true"
            style="-fx-background-color: transparent;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.barbman.core.controller.ServicesViewController">

    <content>
        <VBox alignment="CENTER" fillWidth="true" prefWidth="600.0" spacing="16" style="-fx-padding: 24;">
            <children>

                <!-- PANEL PRINCIPAL -->
                <VBox spacing="12" styleClass="services-section">
                    <children>
                        <Label text="Registrar servicio" styleClass="services-title"/>
                        <!-- Agregar servicios individuales -->
                        <HBox alignment="CENTER" spacing="18" styleClass="services-row">
                            <children>
                                <ComboBox fx:id="serviceComboBox"
                                          prefWidth="220.0"
                                          promptText="Seleccionar servicio"
                                          styleClass="services-combobox"/>

                                <TextField fx:id="priceField"
                                           prefWidth="100.0"
                                           promptText="Precio"
                                           styleClass="services-textfield"/>

                                <Button fx:id="addItemButton"
                                        text="+ Agregar"
                                        prefWidth="100.0"
                                        styleClass="services-button"/>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER" spacing="18" styleClass="services-row">
                        <!-- Tabla de items agregados -->
                        <TableView fx:id="itemsTable"
                                   prefHeight="90.0"
                                   prefWidth="100.0"
                                   styleClass="services-table-mini">
                            <columns>
                                <TableColumn fx:id="colItemServiceType" prefWidth="200" text="Servicio"/>
                                <TableColumn fx:id="colItemPrice" prefWidth="120" text="Precio (Gs)"/>
                                <TableColumn fx:id="colItemRemove" prefWidth="80"  text="Acción"/>
                            </columns>
                        </TableView>
                        </HBox>
                        <!-- Panel secundario -->
                        <VBox spacing="10" styleClass="services-subsection">
                            <children>

                                <!-- Metodo de pago -->
                                <VBox spacing="6" alignment="CENTER">
                                    <children>
                                        <Label text="Método de pago:" style="-fx-font-weight: bold;"/>
                                        <HBox fx:id="paymentButtonsBox" spacing="10" alignment="CENTER"/>
                                    </children>
                                </VBox>
                                <!-- Usuario + notas -->
                                <HBox alignment="CENTER" spacing="18" styleClass="services-row">
                                    <children>
                                        <ComboBox fx:id="userComboBox"
                                                  prefWidth="150.0"
                                                  promptText="Usuario"
                                                  styleClass="services-combobox"/>

                                        <TextField fx:id="notesField"
                                                   prefWidth="250.0"
                                                   promptText="Observaciones"
                                                   styleClass="services-textfield"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- Total + botones -->
                        <HBox alignment="CENTER_RIGHT" spacing="10">
                            <children>

                                <Label text="Total actual:" styleClass="label"/>

                                <!-- BADGE -->
                                <Label fx:id="totalLabel"
                                       text="0 Gs"
                                       styleClass="total-badge"/>

                                <!-- Botón guardar (primario) -->
                                <Button fx:id="saveButton"
                                        text="💾 Guardar"
                                        prefWidth="120.0"
                                        styleClass="services-button"/>

                                <!-- Botón limpiar (secundario) -->
                                <Button fx:id="resetButton"
                                        text="🔄 Limpiar"
                                        prefWidth="100.0"
                                        styleClass="button-secondary"/>

                            </children>
                        </HBox>

                    </children>
                </VBox>

                <!-- Separador -->
                <Separator/>

                <!-- HISTORIAL -->
                <VBox spacing="12" styleClass="services-section">
                    <children>

                        <Label text="Historial de servicios" styleClass="services-title"/>

                        <TableView fx:id="servicesTable"
                                   prefHeight="300.0"
                                   prefWidth="580.0"
                                   styleClass="table-view">
                            <columns>
                                <TableColumn fx:id="colDate" prefWidth="110" text="Fecha"/>
                                <TableColumn fx:id="colUser" prefWidth="100" text="Usuario"/>
                                <TableColumn fx:id="colServiceType" prefWidth="180" text="Detalle servicios"/>
                                <TableColumn fx:id="colPaymentMethod" prefWidth="100" text="Pago"/>
                                <TableColumn fx:id="colPrice" prefWidth="90" text="Total"/>
                                <TableColumn fx:id="colNotes" prefWidth="160" text="Notas"/>
                            </columns>
                        </TableView>

                        <!-- FILTROS -->
                        <HBox alignment="CENTER" spacing="14" styleClass="services-row" style="-fx-padding: 6 0 0 0;">
                            <children>
                                <Label text="Filtrar:"/>

                                <ComboBox fx:id="filterUserComboBox"
                                          prefWidth="130.0"
                                          promptText="Usuario"
                                          styleClass="services-combobox"/>

                                <ComboBox fx:id="dateFilterCombo"
                                          prefWidth="160"
                                          promptText="Rango de fechas"
                                          styleClass="services-combobox"/>

                                <Button fx:id="filterButton"
                                        prefWidth="40.0"
                                        styleClass="services-button">
                                    <graphic>
                                        <FontIcon iconLiteral="fas-check" iconSize="14"/>
                                    </graphic>
                                </Button>

                                <Button fx:id="clearFilterButton"
                                        text="Mostrar todo"
                                        prefWidth="120.0"
                                        styleClass="services-button"/>
                            </children>
                        </HBox>

                    </children>
                </VBox>

            </children>
        </VBox>
    </content>
</ScrollPane>
