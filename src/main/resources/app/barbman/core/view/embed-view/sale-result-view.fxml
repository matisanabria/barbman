<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.barbman.core.controller.sales.SaleResultViewController"
            styleClass="sale-root">

    <!-- TOP - HEADER -->
    <top>
        <VBox alignment="CENTER"
              spacing="8"
              styleClass="sale-result-header">
            <padding>
                <Insets top="20" bottom="20"/>
            </padding>

            <Label text="Comprobante de Venta"
                   styleClass="sale-result-title"/>

            <HBox spacing="16" alignment="CENTER">
                <Label text="N°"
                       styleClass="sale-result-subtitle"/>
                <Label fx:id="saleNumberLabel"
                       text="001"
                       styleClass="sale-result-number"/>
                <Label text="•"
                       styleClass="sale-result-subtitle"/>
                <Label fx:id="saleDateLabel"
                       text="31/01/2026 - 14:30"
                       styleClass="sale-result-subtitle"/>
            </HBox>
        </VBox>
    </top>

    <!-- CENTER - DETAILS -->
    <center>
        <ScrollPane fitToWidth="true"
                    styleClass="sale-scroll">
            <content>
                <VBox spacing="24"
                      fillWidth="true"
                      styleClass="sale-result-content">
                    <padding>
                        <Insets top="20" right="40" bottom="20" left="40"/>
                    </padding>

                    <!-- CLIENTE -->
                    <VBox spacing="10"
                          styleClass="sale-result-section">
                        <Label text="CLIENTE"
                               styleClass="sale-result-section-title"/>

                        <GridPane hgap="16" vgap="8"
                                  styleClass="sale-result-grid">
                            <Label text="Nombre:"
                                   styleClass="sale-result-label"
                                   GridPane.rowIndex="0"
                                   GridPane.columnIndex="0"/>

                            <Label fx:id="clientNameLabel"
                                   text="Cliente casual"
                                   styleClass="sale-result-value"
                                   GridPane.rowIndex="0"
                                   GridPane.columnIndex="1"/>

                            <Label text="RUC / CI:"
                                   styleClass="sale-result-label"
                                   GridPane.rowIndex="1"
                                   GridPane.columnIndex="0"/>

                            <Label fx:id="clientDocLabel"
                                   text="-"
                                   styleClass="sale-result-value"
                                   GridPane.rowIndex="1"
                                   GridPane.columnIndex="1"/>
                        </GridPane>
                    </VBox>

                    <!-- DETALLE -->
                    <VBox spacing="12"
                          styleClass="sale-result-section">
                        <Label text="DETALLE DE LA VENTA"
                               styleClass="sale-result-section-title"/>

                        <!-- Table header -->
                        <HBox spacing="12"
                              styleClass="sale-result-table-header"
                              alignment="CENTER_LEFT">
                            <Label text="Ítem"
                                   styleClass="sale-result-th"
                                   maxWidth="Infinity"
                                   HBox.hgrow="ALWAYS"/>
                            <Label text="Cant."
                                   styleClass="sale-result-th"
                                   prefWidth="60"
                                   alignment="CENTER"/>
                            <Label text="Precio"
                                   styleClass="sale-result-th"
                                   prefWidth="100"
                                   alignment="CENTER_RIGHT"/>
                            <Label text="Subtotal"
                                   styleClass="sale-result-th"
                                   prefWidth="100"
                                   alignment="CENTER_RIGHT"/>
                        </HBox>

                        <!-- Items container -->
                        <VBox fx:id="itemsContainer"
                              spacing="6"
                              styleClass="sale-result-items"
                              fillWidth="true"/>
                    </VBox>

                    <!-- TOTALES -->
                    <VBox spacing="10"
                          styleClass="sale-result-section">
                        <Separator styleClass="sale-result-separator"/>

                        <GridPane hgap="16" vgap="8"
                                  styleClass="sale-result-totals">

                            <!-- Subtotal -->
                            <Label text="Subtotal (gravado 10%):"
                                   styleClass="sale-result-label"
                                   GridPane.rowIndex="0"
                                   GridPane.columnIndex="0"/>
                            <Label fx:id="subtotalLabel"
                                   text="0 Gs"
                                   styleClass="sale-result-value"
                                   GridPane.rowIndex="0"
                                   GridPane.columnIndex="1"/>

                            <!-- IVA -->
                            <Label text="IVA (10%):"
                                   styleClass="sale-result-label"
                                   GridPane.rowIndex="1"
                                   GridPane.columnIndex="0"/>
                            <Label fx:id="ivaLabel"
                                   text="0 Gs"
                                   styleClass="sale-result-value"
                                   GridPane.rowIndex="1"
                                   GridPane.columnIndex="1"/>

                            <!-- Total -->
                            <Label text="TOTAL A PAGAR:"
                                   styleClass="sale-result-total-label"
                                   GridPane.rowIndex="2"
                                   GridPane.columnIndex="0"/>
                            <Label fx:id="totalLabel"
                                   text="0 Gs"
                                   styleClass="sale-result-total-value"
                                   GridPane.rowIndex="2"
                                   GridPane.columnIndex="1"/>
                        </GridPane>

                        <!-- Total en letras -->
                        <Label fx:id="totalInWordsLabel"
                               text="Cero guaraníes"
                               styleClass="sale-result-words"
                               wrapText="true"/>
                    </VBox>

                    <!-- MÉTODO DE PAGO -->
                    <VBox spacing="8"
                          styleClass="sale-result-section">
                        <Label text="Método de pago:"
                               styleClass="sale-result-label"/>
                        <Label fx:id="paymentMethodLabel"
                               text="Efectivo"
                               styleClass="sale-result-payment"/>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

    <!-- BOTTOM - ACTIONS -->
    <bottom>
        <HBox spacing="12"
              alignment="CENTER"
              styleClass="sale-result-footer">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <Button fx:id="newSaleButton"
                    text="Nueva venta"
                    maxWidth="Infinity"
                    HBox.hgrow="ALWAYS"
                    styleClass="sale-confirm-btn"/>
        </HBox>
    </bottom>

</BorderPane>