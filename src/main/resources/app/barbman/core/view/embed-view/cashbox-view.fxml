<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.barbman.core.controller.CashboxController"
            fitToWidth="true"
            styleClass="caja-scrollpane">

    <content>
        <VBox spacing="24" styleClass="caja-root">
            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>

            <!-- ========================================= -->
            <!-- HEADER -->
            <!-- ========================================= -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label text="Caja" styleClass="caja-main-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Cerrar Caja"
                        onAction="#onCloseCashbox"
                        styleClass="caja-btn-close"/>
            </HBox>

            <!-- ========================================= -->
            <!-- CAJA ACTUAL — LIVE BALANCES -->
            <!-- ========================================= -->
            <VBox spacing="14" styleClass="caja-section caja-live-section">
                <Label text="CAJA ACTUAL" styleClass="caja-section-title"/>
                <Label fx:id="lblLiveOpenedSince"
                       text="Abierta desde: --/-- --:--"
                       styleClass="caja-period-label"/>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <!-- EFECTIVO -->
                    <VBox spacing="4" styleClass="caja-card" HBox.hgrow="ALWAYS">
                        <Label text="Efectivo" styleClass="caja-card-title"/>
                        <Separator/>
                        <Label fx:id="lblLiveCash" text="0 Gs" styleClass="caja-balance"/>
                    </VBox>

                    <!-- BANCO -->
                    <VBox spacing="4" styleClass="caja-card" HBox.hgrow="ALWAYS">
                        <Label text="Banco" styleClass="caja-card-title"/>
                        <Separator/>
                        <Label fx:id="lblLiveBank" text="0 Gs" styleClass="caja-balance"/>
                    </VBox>

                    <!-- TOTAL -->
                    <VBox spacing="4" styleClass="caja-card caja-card-total" HBox.hgrow="ALWAYS">
                        <Label text="Total" styleClass="caja-card-title"/>
                        <Separator/>
                        <Label fx:id="lblLiveTotal" text="0 Gs" styleClass="caja-total"/>
                    </VBox>
                </HBox>

                <!-- MINI RESUMEN: INGRESOS / EGRESOS DEL PERIODO -->
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <VBox spacing="2" styleClass="caja-summary-card" HBox.hgrow="ALWAYS">
                        <Label text="Total Ingresos" styleClass="caja-summary-label"/>
                        <Label fx:id="lblLiveTotalIn" text="0 Gs" styleClass="caja-amount-in caja-summary-amount"/>
                    </VBox>
                    <VBox spacing="2" styleClass="caja-summary-card" HBox.hgrow="ALWAYS">
                        <Label text="Total Egresos" styleClass="caja-summary-label"/>
                        <Label fx:id="lblLiveTotalOut" text="0 Gs" styleClass="caja-amount-out caja-summary-amount"/>
                    </VBox>
                </HBox>
            </VBox>

            <Separator/>

            <!-- ========================================= -->
            <!-- RESUMEN DIARIO -->
            <!-- ========================================= -->
            <VBox spacing="16" styleClass="caja-section">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Resumen Diario" styleClass="caja-section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <DatePicker fx:id="dateFechas"
                                prefWidth="160"
                                styleClass="caja-choice"/>
                </HBox>

                <Label fx:id="lblFechaDiaria"
                       text="Fecha: --/--/----"
                       styleClass="caja-period-label"/>

                <!-- Cards: Efectivo y Banco -->
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <VBox spacing="8" styleClass="caja-card" HBox.hgrow="ALWAYS">
                        <Label text="Efectivo" styleClass="caja-card-title"/>
                        <Separator/>
                        <Label fx:id="lblCashInDiaria" text="+ 0 Gs" styleClass="caja-amount-in"/>
                        <Label fx:id="lblCashOutDiaria" text="- 0 Gs" styleClass="caja-amount-out"/>
                    </VBox>

                    <VBox spacing="8" styleClass="caja-card" HBox.hgrow="ALWAYS">
                        <Label text="Banco" styleClass="caja-card-title"/>
                        <Separator/>
                        <Label fx:id="lblBankInDiaria" text="+ 0 Gs" styleClass="caja-amount-in"/>
                        <Label fx:id="lblBankOutDiaria" text="- 0 Gs" styleClass="caja-amount-out"/>
                    </VBox>
                </HBox>

                <!-- Resumen Total: Ingresos / Egresos / Balance -->
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <VBox spacing="2" styleClass="caja-summary-card" HBox.hgrow="ALWAYS">
                        <Label text="Total Ingresos" styleClass="caja-summary-label"/>
                        <Label fx:id="lblTotalInDiaria" text="+ 0 Gs" styleClass="caja-amount-in caja-summary-amount"/>
                    </VBox>
                    <VBox spacing="2" styleClass="caja-summary-card" HBox.hgrow="ALWAYS">
                        <Label text="Total Egresos" styleClass="caja-summary-label"/>
                        <Label fx:id="lblTotalOutDiaria" text="- 0 Gs" styleClass="caja-amount-out caja-summary-amount"/>
                    </VBox>
                    <VBox spacing="2" styleClass="caja-summary-card caja-card-total" HBox.hgrow="ALWAYS">
                        <Label text="Balance" styleClass="caja-summary-label"/>
                        <Label fx:id="lblTotalBalanceDiaria" text="0 Gs" styleClass="caja-total"/>
                    </VBox>
                </HBox>

                <!-- Produccion + Grafico -->
                <HBox spacing="16" alignment="TOP_LEFT">
                    <VBox spacing="8" styleClass="caja-production" HBox.hgrow="ALWAYS" maxWidth="400">
                        <Label text="Produccion por empleado" styleClass="caja-production-title"/>
                        <VBox fx:id="boxProduccionDiaria" spacing="4"/>
                    </VBox>
                    <VBox fx:id="chartContainerDiario" styleClass="caja-chart-container"
                          HBox.hgrow="ALWAYS" minHeight="250" alignment="CENTER"/>
                </HBox>

            </VBox>

            <Separator/>

            <!-- ========================================= -->
            <!-- RESUMEN SEMANAL -->
            <!-- ========================================= -->
            <VBox spacing="16" styleClass="caja-section">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Resumen Semanal" styleClass="caja-section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <ChoiceBox fx:id="choiceSemanas"
                               prefWidth="270"
                               styleClass="caja-choice"/>
                </HBox>

                <Label fx:id="lblSemana"
                       text="Semana: --/-- -> --/--"
                       styleClass="caja-period-label"/>

                <!-- Cards: Efectivo y Banco -->
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <VBox spacing="8" styleClass="caja-card" HBox.hgrow="ALWAYS">
                        <Label text="Efectivo" styleClass="caja-card-title"/>
                        <Separator/>
                        <Label fx:id="lblCashInSemanal" text="+ 0 Gs" styleClass="caja-amount-in"/>
                        <Label fx:id="lblCashOutSemanal" text="- 0 Gs" styleClass="caja-amount-out"/>
                    </VBox>

                    <VBox spacing="8" styleClass="caja-card" HBox.hgrow="ALWAYS">
                        <Label text="Banco" styleClass="caja-card-title"/>
                        <Separator/>
                        <Label fx:id="lblBankInSemanal" text="+ 0 Gs" styleClass="caja-amount-in"/>
                        <Label fx:id="lblBankOutSemanal" text="- 0 Gs" styleClass="caja-amount-out"/>
                    </VBox>
                </HBox>

                <!-- Resumen Total -->
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <VBox spacing="2" styleClass="caja-summary-card" HBox.hgrow="ALWAYS">
                        <Label text="Total Ingresos" styleClass="caja-summary-label"/>
                        <Label fx:id="lblTotalInSemanal" text="+ 0 Gs" styleClass="caja-amount-in caja-summary-amount"/>
                    </VBox>
                    <VBox spacing="2" styleClass="caja-summary-card" HBox.hgrow="ALWAYS">
                        <Label text="Total Egresos" styleClass="caja-summary-label"/>
                        <Label fx:id="lblTotalOutSemanal" text="- 0 Gs" styleClass="caja-amount-out caja-summary-amount"/>
                    </VBox>
                    <VBox spacing="2" styleClass="caja-summary-card caja-card-total" HBox.hgrow="ALWAYS">
                        <Label text="Balance" styleClass="caja-summary-label"/>
                        <Label fx:id="lblTotalBalanceSemanal" text="0 Gs" styleClass="caja-total"/>
                    </VBox>
                </HBox>

                <!-- Produccion -->
                <VBox spacing="8" styleClass="caja-production">
                    <Label text="Produccion por empleado" styleClass="caja-production-title"/>
                    <VBox fx:id="boxProduccionSemanal" spacing="4"/>
                </VBox>

                <!-- Grafico semanal -->
                <VBox fx:id="chartContainerSemanal" styleClass="caja-chart-container"
                      minHeight="300" alignment="CENTER"/>

            </VBox>

            <Separator/>

            <!-- ========================================= -->
            <!-- RESUMEN MENSUAL -->
            <!-- ========================================= -->
            <VBox spacing="16" styleClass="caja-section">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Resumen Mensual" styleClass="caja-section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <ChoiceBox fx:id="choiceMeses"
                               prefWidth="200"
                               styleClass="caja-choice"/>
                </HBox>

                <Label fx:id="lblMes"
                       text="Mes: ----"
                       styleClass="caja-period-label"/>

                <!-- Cards: Efectivo y Banco -->
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <VBox spacing="8" styleClass="caja-card" HBox.hgrow="ALWAYS">
                        <Label text="Efectivo" styleClass="caja-card-title"/>
                        <Separator/>
                        <Label fx:id="lblCashInMensual" text="+ 0 Gs" styleClass="caja-amount-in"/>
                        <Label fx:id="lblCashOutMensual" text="- 0 Gs" styleClass="caja-amount-out"/>
                    </VBox>

                    <VBox spacing="8" styleClass="caja-card" HBox.hgrow="ALWAYS">
                        <Label text="Banco" styleClass="caja-card-title"/>
                        <Separator/>
                        <Label fx:id="lblBankInMensual" text="+ 0 Gs" styleClass="caja-amount-in"/>
                        <Label fx:id="lblBankOutMensual" text="- 0 Gs" styleClass="caja-amount-out"/>
                    </VBox>
                </HBox>

                <!-- Resumen Total -->
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <VBox spacing="2" styleClass="caja-summary-card" HBox.hgrow="ALWAYS">
                        <Label text="Total Ingresos" styleClass="caja-summary-label"/>
                        <Label fx:id="lblTotalInMensual" text="+ 0 Gs" styleClass="caja-amount-in caja-summary-amount"/>
                    </VBox>
                    <VBox spacing="2" styleClass="caja-summary-card" HBox.hgrow="ALWAYS">
                        <Label text="Total Egresos" styleClass="caja-summary-label"/>
                        <Label fx:id="lblTotalOutMensual" text="- 0 Gs" styleClass="caja-amount-out caja-summary-amount"/>
                    </VBox>
                    <VBox spacing="2" styleClass="caja-summary-card caja-card-total" HBox.hgrow="ALWAYS">
                        <Label text="Balance" styleClass="caja-summary-label"/>
                        <Label fx:id="lblTotalBalanceMensual" text="0 Gs" styleClass="caja-total"/>
                    </VBox>
                </HBox>

                <!-- Produccion -->
                <VBox spacing="8" styleClass="caja-production">
                    <Label text="Produccion por empleado" styleClass="caja-production-title"/>
                    <VBox fx:id="boxProduccionMensual" spacing="4"/>
                </VBox>

                <!-- Grafico mensual -->
                <VBox fx:id="chartContainerMensual" styleClass="caja-chart-container"
                      minHeight="300" alignment="CENTER"/>

            </VBox>

        </VBox>
    </content>

</ScrollPane>
