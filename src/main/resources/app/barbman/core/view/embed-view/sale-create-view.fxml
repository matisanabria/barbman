<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.barbman.core.controller.sales.SaleCreateViewController"
            styleClass="sale-root">

    <!-- =====================
         TOP - TITLE
         ===================== -->
    <top>
        <HBox alignment="CENTER"
              prefHeight="56"
              styleClass="sale-topbar">
            <Label text="Registrar venta"
                   styleClass="sale-title"
            fx:id="saleCreateTitle"/>
        </HBox>
    </top>

    <!-- =====================
         RIGHT - CART
         ===================== -->
    <right>
        <VBox spacing="12"
              prefWidth="420"
              BorderPane.alignment="CENTER"
              styleClass="sale-cart">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <!-- Header -->
            <HBox spacing="24"
                  styleClass="sale-cart-header">
                <Label text="Item" styleClass="sale-cart-header-text"/>
                <Label text="Precio" styleClass="sale-cart-header-text"/>
                <Label text="Cantidad" styleClass="sale-cart-header-text"/>
            </HBox>

            <!-- Cart list -->
            <ScrollPane fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        styleClass="sale-scroll">
                <content>
                    <VBox fx:id="cartContainer"
                          spacing="10"
                          fillWidth="true"/>
                </content>
            </ScrollPane>

            <!-- Total -->
            <HBox alignment="CENTER_RIGHT"
                  spacing="6"
                  styleClass="sale-total-row">
                <Label text="Total:"
                       styleClass="sale-total-label"/>
                <Label fx:id="totalLabel"
                       text="0 Gs"
                       styleClass="sale-total-value"/>
            </HBox>

            <!-- Confirm -->
            <Button fx:id="confirmButton"
                    text="Confirmar"
                    maxWidth="Infinity"
                    styleClass="sale-confirm-btn"/>
        </VBox>
    </right>

    <!-- =====================
         CENTER - ITEMS
         ===================== -->
    <center>
        <VBox spacing="12"
              fillWidth="true"
              styleClass="sale-center">
            <padding>
                <Insets top="16" right="100" bottom="16" left="100"/>
            </padding>

            <!-- TOGGLES -->
            <HBox alignment="CENTER"
                  spacing="10"
                  styleClass="sale-toggle-group">
                <ToggleButton fx:id="servicesToggle"
                              text="Servicios"
                              selected="true"
                              styleClass="sale-toggle"/>

                <ToggleButton fx:id="productsToggle"
                              text="Productos"
                              styleClass="sale-toggle"/>
            </HBox>

            <!-- LISTA DE ITEMS -->
            <ScrollPane fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        styleClass="sale-scroll">
                <content>
                    <VBox fx:id="servicesListContainer"
                          spacing="12"
                          fillWidth="true"/>
                </content>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
