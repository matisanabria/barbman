<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="sale-root"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.barbman.core.controller.sales.SaleCreateViewController">

    <!-- =====================
         TOP - TITLE & STATS
         ===================== -->
    <top>
        <VBox styleClass="sale-header">
            <!-- Title bar with user selector -->
            <HBox alignment="CENTER_LEFT"
                  spacing="20"
                  prefHeight="56"
                  styleClass="sale-topbar">
                <padding>
                    <Insets left="20" right="20"/>
                </padding>

                <Label fx:id="saleCreateTitle"
                       text="💰 Ventas"
                       styleClass="sale-title"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- User selector -->
                <Label text="Registrar a:"
                       styleClass="user-selector-label"/>

                <ComboBox fx:id="userComboBox"
                          styleClass="user-selector-combo"
                          prefWidth="200">
                    <!-- Items serán cargados desde el controller -->
                </ComboBox>
            </HBox>

            <!-- Stats bar -->
            <HBox spacing="20"
                  alignment="CENTER"
                  styleClass="sale-stats">
                <padding>
                    <Insets top="12" bottom="12"/>
                </padding>

                <VBox alignment="CENTER" styleClass="stat-card">
                    <Label text="HOY" styleClass="stat-label"/>
                    <Label fx:id="todayTotalLabel" text="0 Gs" styleClass="stat-value"/>
                </VBox>

                <Separator orientation="VERTICAL"/>

                <VBox alignment="CENTER" styleClass="stat-card">
                    <Label text="ESTA SEMANA" styleClass="stat-label"/>
                    <Label fx:id="weekTotalLabel" text="0 Gs" styleClass="stat-value"/>
                </VBox>

                <Separator orientation="VERTICAL"/>

                <VBox alignment="CENTER" styleClass="stat-card">
                    <Label text="ESTE MES" styleClass="stat-label"/>
                    <Label fx:id="monthTotalLabel" text="0 Gs" styleClass="stat-value"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <!-- =====================
         RIGHT - CART PANEL
         ===================== -->
    <right>
        <VBox prefWidth="450"
              spacing="16"
              styleClass="sale-cart-panel">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- Cart header -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="🛒 CARRITO"
                       styleClass="cart-title"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="cartItemsCount"
                       text="0 ítems"
                       styleClass="cart-count"/>
            </HBox>

            <!-- Cart items (scrollable) -->
            <ScrollPane fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        styleClass="cart-scroll">
                <VBox fx:id="cartContainer"
                      fillWidth="true"
                      spacing="10"
                      styleClass="cart-items-container"/>
            </ScrollPane>

            <!-- Separator -->
            <Separator styleClass="cart-separator"/>

            <!-- Total -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="TOTAL:"
                       styleClass="cart-total-label"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="totalLabel"
                       text="0 Gs"
                       styleClass="cart-total-value"/>
            </HBox>

            <!-- Confirm button -->
            <Button fx:id="confirmButton"
                    text="✅ CONFIRMAR VENTA"
                    maxWidth="Infinity"
                    styleClass="sale-confirm-btn"/>
        </VBox>
    </right>

    <!-- =====================
         CENTER - ITEMS GRID
         ===================== -->
    <center>
        <VBox fillWidth="true"
              spacing="16"
              styleClass="sale-center-panel"
              VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- Toggle selector -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label text="📋 SELECCIONAR"
                       styleClass="center-title"/>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox spacing="0" styleClass="sale-toggle-group">
                    <ToggleButton fx:id="servicesToggle"
                                  selected="true"
                                  styleClass="sale-toggle"
                                  text="Servicios"/>

                    <ToggleButton fx:id="productsToggle"
                                  styleClass="sale-toggle"
                                  text="Productos"/>
                </HBox>
            </HBox>

            <!-- Items grid (scrollable, fills remaining space) -->
            <ScrollPane fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        styleClass="items-scroll">
                <VBox fx:id="servicesListContainer"
                      fillWidth="true"
                      spacing="12"
                      styleClass="items-container"/>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>