<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="sale-root" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.barbman.core.controller.sales.SaleCreateViewController">

    <!-- =====================
         TOP - TITLE
         ===================== -->
    <top>
        <HBox alignment="CENTER" prefHeight="56" styleClass="sale-topbar">
            <Label fx:id="saleCreateTitle" styleClass="sale-title" text="Registrar venta" />
        </HBox>
    </top>

    <!-- =====================
         RIGHT - CART
         ===================== -->
    <right>
        <VBox prefWidth="420" spacing="12" styleClass="sale-cart" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="16" left="16" right="16" top="16" />
            </padding>

            <!-- Cart list -->
            <ScrollPane fitToWidth="true" styleClass="sale-scroll" VBox.vgrow="ALWAYS">
                <content>
                    <VBox fx:id="cartContainer" fillWidth="true" spacing="10" />
                </content>
            </ScrollPane>

            <!-- Total -->
            <HBox alignment="CENTER_RIGHT" spacing="6" styleClass="sale-total-row">
                <Label styleClass="sale-total-label" text="Total:" />
                <Label fx:id="totalLabel" styleClass="sale-total-value" text="0 Gs" />
            </HBox>

            <!-- Confirm -->
            <Button fx:id="confirmButton" maxWidth="Infinity" styleClass="sale-confirm-btn" text="Confirmar" />
        </VBox>
    </right>

    <!-- =====================
         CENTER - ITEMS
         ===================== -->
    <center>
        <VBox fillWidth="true" spacing="12" styleClass="sale-center">
            <padding>
                <Insets bottom="16" left="100" right="100" top="16" />
            </padding>

            <!-- TOGGLES -->
            <HBox alignment="CENTER" spacing="10" styleClass="sale-toggle-group">
                <ToggleButton fx:id="servicesToggle" selected="true" styleClass="sale-toggle" text="Servicios" />

                <ToggleButton fx:id="productsToggle" styleClass="sale-toggle" text="Productos" />
            </HBox>

            <!-- LISTA DE ITEMS -->
            <ScrollPane fitToWidth="true" styleClass="sale-scroll" VBox.vgrow="ALWAYS">
                <content>
                    <VBox fx:id="servicesListContainer" fillWidth="true" spacing="12" />
                </content>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
