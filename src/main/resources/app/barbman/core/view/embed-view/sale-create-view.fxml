<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.barbman.core.controller.sales.SaleCreateViewController"
            style="-fx-background-color: #232323;">

    <!-- =====================
         TOP - TITLE
         ===================== -->
    <top>
        <HBox alignment="CENTER"
              prefHeight="56"
              style="-fx-background-color: #232323;">
            <children>
                <Label text="Registrar venta"
                       style="
                           -fx-text-fill: #FFFFFF;
                           -fx-font-size: 22px;
                           -fx-font-weight: bold;
                           -fx-font-family: 'Inter 24pt Regular', Arial, sans-serif;
                       "/>
            </children>
        </HBox>
    </top>

    <!-- =====================
         RIGHT - CART
         ===================== -->
    <right>
        <VBox spacing="12"
              prefWidth="420"
              BorderPane.alignment="CENTER"
              style="-fx-background-color: #232323;">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <!-- Header -->
            <HBox spacing="24">
                <Label text="Item"
                       style="-fx-text-fill: #CCCCCC; -fx-font-size: 13px;"/>
                <Label text="Precio"
                       style="-fx-text-fill: #CCCCCC; -fx-font-size: 13px;"/>
                <Label text="Cantidad"
                       style="-fx-text-fill: #CCCCCC; -fx-font-size: 13px;"/>
            </HBox>

            <!-- Cart list -->
            <ScrollPane fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        style="-fx-background: #232323;">
                <content>
                    <VBox fx:id="cartContainer"
                          spacing="10"
                          fillWidth="true"/>
                </content>
            </ScrollPane>

            <!-- Total -->
            <HBox alignment="CENTER_RIGHT"
                  spacing="6">
                <Label text="Total:"
                       style="-fx-text-fill: #CCCCCC; -fx-font-size: 13px;"/>

                <Label fx:id="totalLabel"
                       text="0 Gs"
                       style="
                           -fx-text-fill: #F0C667;
                           -fx-font-size: 20px;
                           -fx-font-weight: bold;
                       "/>
            </HBox>

            <!-- Confirm -->
            <Button fx:id="confirmButton"
                    text="Confirmar"
                    maxWidth="Infinity"
                    style="
                        -fx-background-color: #F0C667;
                        -fx-background-radius: 12;
                        -fx-text-fill: #232323;
                        -fx-font-size: 15px;
                        -fx-font-weight: bold;
                        -fx-cursor: hand;
                    "/>
        </VBox>
    </right>

    <!-- =====================
         CENTER - ITEMS
         ===================== -->
    <center>
        <VBox spacing="12"
              fillWidth="true"
              style="-fx-background-color: #232323;">

            <!-- TOGGLES -->
            <HBox alignment="CENTER"
                  spacing="10">
                <children>
                    <ToggleButton fx:id="servicesToggle"
                                  text="Servicios"
                                  selected="true"
                                  style="
                                      -fx-background-color: #2F2F2F;
                                      -fx-background-radius: 12;
                                      -fx-text-fill: #FFFFFF;
                                  "/>

                    <ToggleButton fx:id="productsToggle"
                                  text="Productos"
                                  style="
                                      -fx-background-color: #2F2F2F;
                                      -fx-background-radius: 12;
                                      -fx-text-fill: #FFFFFF;
                                  "/>
                </children>
            </HBox>

            <!-- LISTA DE ITEMS -->
            <ScrollPane fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        style="-fx-background: #232323;">
                <content>
                    <VBox fx:id="servicesListContainer"
                          spacing="12"
                          fillWidth="true"/>
                </content>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
