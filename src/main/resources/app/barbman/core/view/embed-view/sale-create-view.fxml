<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="sale-root"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.barbman.core.controller.sales.SaleCreateViewController">

    <!-- =====================
         TOP
         ===================== -->
    <top>
        <VBox styleClass="sale-header">
            <HBox alignment="CENTER_LEFT"
                  spacing="16"
                  prefHeight="56"
                  styleClass="sale-topbar">
                <padding>
                    <Insets left="24" right="24"/>
                </padding>

                <Label fx:id="saleCreateTitle"
                       text="Ventas"
                       styleClass="sale-title"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Stats inline -->
                <HBox spacing="24" alignment="CENTER_RIGHT" styleClass="sale-stats-inline">
                    <VBox alignment="CENTER" spacing="0">
                        <Label text="HOY" styleClass="stat-label-sm"/>
                        <Label fx:id="todayTotalLabel" text="0 Gs" styleClass="stat-value-sm"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="0">
                        <Label text="SEMANA" styleClass="stat-label-sm"/>
                        <Label fx:id="weekTotalLabel" text="0 Gs" styleClass="stat-value-sm"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="0">
                        <Label text="MES" styleClass="stat-label-sm"/>
                        <Label fx:id="monthTotalLabel" text="0 Gs" styleClass="stat-value-sm"/>
                    </VBox>
                </HBox>

                <Separator orientation="VERTICAL" styleClass="topbar-sep"/>

                <Label text="Barbero:" styleClass="user-selector-label"/>
                <ComboBox fx:id="userComboBox"
                          styleClass="user-selector-combo"
                          prefWidth="180"/>
            </HBox>
        </VBox>
    </top>

    <!-- =====================
         RIGHT - CART
         ===================== -->
    <right>
        <VBox prefWidth="380"
              spacing="0"
              styleClass="cart-panel">

            <!-- Cart header -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  styleClass="cart-header">
                <padding>
                    <Insets top="16" right="20" bottom="12" left="20"/>
                </padding>
                <Label text="Carrito" styleClass="cart-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="cartItemsCount" text="0" styleClass="cart-badge"/>
            </HBox>

            <!-- Cart items -->
            <ScrollPane fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        styleClass="cart-scroll">
                <padding>
                    <Insets left="12" right="12"/>
                </padding>
                <VBox fx:id="cartContainer"
                      fillWidth="true"
                      spacing="6"
                      styleClass="cart-items"/>
            </ScrollPane>

            <!-- Cart footer -->
            <VBox spacing="12" styleClass="cart-footer">
                <padding>
                    <Insets top="16" right="20" bottom="20" left="20"/>
                </padding>

                <Separator styleClass="cart-sep"/>

                <HBox alignment="CENTER_LEFT">
                    <Label text="TOTAL" styleClass="cart-total-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="totalLabel" text="0 Gs" styleClass="cart-total-value"/>
                </HBox>

                <Button fx:id="confirmButton"
                        text="CONFIRMAR VENTA"
                        maxWidth="Infinity"
                        styleClass="sale-confirm-btn"/>
            </VBox>
        </VBox>
    </right>

    <!-- =====================
         CENTER - ITEMS
         ===================== -->
    <center>
        <VBox fillWidth="true"
              spacing="12"
              styleClass="center-panel">
            <padding>
                <Insets top="16" right="20" bottom="16" left="20"/>
            </padding>

            <!-- Search + Toggle row -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="searchField"
                           promptText="Buscar servicio o producto..."
                           styleClass="sale-search"
                           HBox.hgrow="ALWAYS"/>

                <HBox spacing="0" styleClass="toggle-pill">
                    <ToggleButton fx:id="servicesToggle"
                                  selected="true"
                                  styleClass="toggle-btn"
                                  text="Servicios"/>
                    <ToggleButton fx:id="productsToggle"
                                  styleClass="toggle-btn"
                                  text="Productos"/>
                </HBox>
            </HBox>

            <!-- Items grid -->
            <ScrollPane fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        styleClass="items-scroll">
                <FlowPane fx:id="itemsGrid"
                          hgap="10" vgap="10"
                          styleClass="items-grid"/>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>
