<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.barbman.core.controller.sales.SalePaymentViewController"
            styleClass="sale-root">

    <!-- TOP - TITLE -->
    <top>
        <HBox alignment="CENTER"
              prefHeight="56"
              styleClass="sale-topbar">
            <Label text="Pago"
                   styleClass="sale-title"/>
        </HBox>
    </top>

    <!-- CENTER - CLIENT & NOTE -->
    <center>
        <VBox spacing="20"
              fillWidth="true"
              styleClass="sale-center">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <!-- Cliente -->
            <!-- Cliente -->
            <VBox spacing="8">
                <Label text="Cliente"
                       styleClass="sale-payment-section-title"/>

                <HBox spacing="8"
                      alignment="CENTER_LEFT">
                    <ComboBox fx:id="clientComboBox"
                              editable="true"
                              prefWidth="400"
                              styleClass="sale-payment-combo"
                              HBox.hgrow="ALWAYS"/>

                    <Button fx:id="addClientButton"
                            text="+"
                            prefWidth="40"
                            prefHeight="40"
                            styleClass="sale-payment-add-client"/>
                </HBox>

                <!-- INFO DEL CLIENTE SELECCIONADO -->
                <VBox fx:id="clientInfoContainer"
                      spacing="4"
                      styleClass="client-info-container"
                      visible="false"
                      managed="false">

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Nombre:" styleClass="client-info-label-key"/>
                        <Label fx:id="clientNameLabel" styleClass="client-info-label-value"/>
                    </HBox>

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="RUC/CI:" styleClass="client-info-label-key"/>
                        <Label fx:id="clientDocumentLabel" styleClass="client-info-label-value"/>
                    </HBox>

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Telefono:" styleClass="client-info-label-key"/>
                        <Label fx:id="clientPhoneLabel" styleClass="client-info-label-value"/>
                    </HBox>

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Email:" styleClass="client-info-label-key"/>
                        <Label fx:id="clientEmailLabel" styleClass="client-info-label-value"/>
                    </HBox>

                </VBox>
            </VBox>

            <!-- Nota -->
            <VBox spacing="8">
                <Label text="Nota (opcional)"
                       styleClass="sale-payment-section-title"/>

                <TextArea fx:id="noteArea"
                          prefRowCount="3"
                          promptText="Insertar nota"
                          styleClass="sale-payment-textarea"/>
            </VBox>

            <!-- Resumen -->
            <VBox spacing="8"
                  VBox.vgrow="ALWAYS">
                <Label text="Resumen"
                       styleClass="sale-payment-section-title"/>

                <ScrollPane fitToWidth="true"
                            VBox.vgrow="ALWAYS"
                            styleClass="sale-scroll">
                    <content>
                        <VBox fx:id="summaryContainer"
                              spacing="8"
                              styleClass="sale-payment-summary-ticket"
                              fillWidth="true"/>
                    </content>
                </ScrollPane>
            </VBox>

        </VBox>
    </center>

    <!-- RIGHT - PAYMENT -->
    <right>
        <VBox spacing="16"
              prefWidth="360"
              BorderPane.alignment="CENTER"
              styleClass="sale-cart">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <!-- Total -->
            <VBox spacing="4">
                <Label text="Total a pagar:"
                       styleClass="sale-payment-label"/>

                <Label fx:id="totalLabel"
                       text="0 Gs"
                       styleClass="sale-payment-amount"/>
            </VBox>

            <!-- Metodo de pago -->
            <VBox spacing="8">
                <Label text="Método de pago"
                       styleClass="sale-payment-label"/>

                <GridPane hgap="8" vgap="8"
                          styleClass="sale-payment-grid">
                    <children>
                        <ToggleButton fx:id="cashToggle"
                                      text="Efectivo"
                                      styleClass="sale-payment-toggle"
                                      GridPane.rowIndex="0"
                                      GridPane.columnIndex="0"/>

                        <ToggleButton fx:id="transferToggle"
                                      text="Transferencia"
                                      styleClass="sale-payment-toggle"
                                      GridPane.rowIndex="0"
                                      GridPane.columnIndex="1"/>

                        <ToggleButton fx:id="cardToggle"
                                      text="Tarjeta"
                                      styleClass="sale-payment-toggle"
                                      GridPane.rowIndex="1"
                                      GridPane.columnIndex="0"/>

                        <ToggleButton fx:id="qrToggle"
                                      text="QR"
                                      styleClass="sale-payment-toggle"
                                      GridPane.rowIndex="1"
                                      GridPane.columnIndex="1"/>
                    </children>
                </GridPane>
            </VBox>

            <!-- Monto recibido -->
            <VBox spacing="6">
                <Label text="Monto recibido"
                       styleClass="sale-payment-label"/>

                <TextField fx:id="receivedAmountField"
                           disable="true"
                           styleClass="sale-payment-field"/>
            </VBox>

            <!-- Vuelto -->
            <VBox spacing="4">
                <Label text="Vuelto:"
                       styleClass="sale-payment-label"/>

                <Label fx:id="changeLabel"
                       text="0 Gs"
                       styleClass="sale-payment-amount"/>
            </VBox>

            <!-- Actions -->
            <HBox spacing="10">
                <Button fx:id="cancelButton"
                        text="Cancelar"
                        maxWidth="Infinity"
                        HBox.hgrow="ALWAYS"
                        styleClass="sale-payment-cancel"/>

                <Button fx:id="confirmButton"
                        text="Confirmar"
                        maxWidth="Infinity"
                        HBox.hgrow="ALWAYS"
                        styleClass="sale-confirm-btn"/>
            </HBox>

        </VBox>
    </right>

</BorderPane>