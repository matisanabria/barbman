<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.barbman.core.controller.sales.SalePaymentViewController"
            style="-fx-background-color: #232323;">

    <!-- =====================
         TOP - TITLE
         ===================== -->
    <top>
        <HBox alignment="CENTER"
              prefHeight="56"
              style="-fx-background-color: #232323;">
            <children>
                <Label text="Pago"
                       style="
                           -fx-text-fill: #FFFFFF;
                           -fx-font-size: 22px;
                           -fx-font-weight: bold;
                           -fx-font-family: 'Inter 24pt Regular', Arial, sans-serif;
                       "/>
            </children>
        </HBox>
    </top>

    <!-- =====================
         CENTER - CLIENT & NOTE
         ===================== -->
    <center>
        <VBox spacing="16"
              fillWidth="true"
              style="-fx-background-color: #232323;">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <!-- Cliente -->
            <HBox spacing="8"
                  alignment="CENTER_LEFT">
                <ComboBox fx:id="clientComboBox"
                          editable="true"
                          minWidth="220"
                          prefWidth="Infinity"
                          HBox.hgrow="ALWAYS"/>

                <Button fx:id="addClientButton"
                        text="+"
                        prefWidth="36"
                        style="
                            -fx-background-color: #3A3A3A;
                            -fx-background-radius: 12;
                            -fx-text-fill: #FFFFFF;
                            -fx-font-weight: bold;
                        "/>
            </HBox>

            <!-- Nota -->
            <VBox spacing="6">
                <Label text="Nota (opcional)"
                       style="
                           -fx-text-fill: #CCCCCC;
                           -fx-font-size: 13px;
                       "/>

                <TextArea fx:id="noteArea"
                          prefRowCount="3"
                          style="
                              -fx-background-color: #232323;
                              -fx-text-fill: #FFFFFF;
                          "/>
            </VBox>

            <!-- Resumen -->
            <VBox spacing="6"
                  VBox.vgrow="ALWAYS">
                <Label text="Resumen"
                       style="
                           -fx-text-fill: #CCCCCC;
                           -fx-font-size: 13px;
                       "/>

                <ScrollPane fitToWidth="true"
                            VBox.vgrow="ALWAYS"
                            style="-fx-background: #232323;">
                    <content>
                        <VBox fx:id="summaryContainer"
                              spacing="8"
                              fillWidth="true"/>
                    </content>
                </ScrollPane>
            </VBox>

        </VBox>
    </center>

    <!-- =====================
         RIGHT - PAYMENT
         ===================== -->
    <right>
        <VBox spacing="16"
              prefWidth="360"
              BorderPane.alignment="CENTER"
              style="-fx-background-color: #232323;">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <!-- Total -->
            <VBox spacing="4">
                <Label text="Total a pagar:"
                       style="
                           -fx-text-fill: #CCCCCC;
                           -fx-font-size: 13px;
                       "/>

                <Label fx:id="totalLabel"
                       text="0 Gs"
                       style="
                           -fx-text-fill: #F0C667;
                           -fx-font-size: 20px;
                           -fx-font-weight: bold;
                       "/>
            </VBox>

            <!-- Metodo de pago -->
            <VBox spacing="8">
                <Label text="Método de pago"
                       style="
                           -fx-text-fill: #CCCCCC;
                           -fx-font-size: 13px;
                       "/>

                <GridPane hgap="8" vgap="8">
                    <children>
                        <ToggleButton fx:id="cashToggle"
                                      text="Efectivo"
                                      style="
                  -fx-background-radius: 12;
                  -fx-font-weight: bold;
              "
                                      GridPane.rowIndex="0"
                                      GridPane.columnIndex="0"/>

                        <ToggleButton fx:id="transferToggle"
                                      text="Transferencia"
                                      style="
                  -fx-background-radius: 12;
                  -fx-font-weight: bold;
              "
                                      GridPane.rowIndex="0"
                                      GridPane.columnIndex="1"/>

                        <ToggleButton fx:id="posToggle"
                                      text="POS"
                                      style="
                  -fx-background-radius: 12;
                  -fx-font-weight: bold;
              "
                                      GridPane.rowIndex="1"
                                      GridPane.columnIndex="0"/>

                        <ToggleButton fx:id="qrToggle"
                                      text="QR"
                                      style="
                  -fx-background-radius: 12;
                  -fx-font-weight: bold;
              "
                                      GridPane.rowIndex="1"
                                      GridPane.columnIndex="1"/>

                    </children>
                </GridPane>
            </VBox>

            <!-- Monto recibido -->
            <VBox spacing="6">
                <Label text="Monto recibido"
                       style="
                           -fx-text-fill: #CCCCCC;
                           -fx-font-size: 13px;
                       "/>

                <TextField fx:id="receivedAmountField"
                           disable="true"
                           style="
                               -fx-background-color: #232323;
                               -fx-text-fill: #FFFFFF;
                           "/>
            </VBox>

            <!-- Vuelto -->
            <VBox spacing="4">
                <Label text="Vuelto:"
                       style="
                           -fx-text-fill: #CCCCCC;
                           -fx-font-size: 13px;
                       "/>

                <Label fx:id="changeLabel"
                       text="0 Gs"
                       style="
                           -fx-text-fill: #F0C667;
                           -fx-font-weight: bold;
                       "/>
            </VBox>

            <!-- Actions -->
            <HBox spacing="10">
                <Button fx:id="cancelButton"
                        text="Cancelar"
                        maxWidth="Infinity"
                        HBox.hgrow="ALWAYS"
                        style="
                            -fx-background-color: #3A3A3A;
                            -fx-background-radius: 12;
                            -fx-text-fill: #FFFFFF;
                        "/>

                <Button fx:id="confirmButton"
                        text="Confirmar"
                        maxWidth="Infinity"
                        HBox.hgrow="ALWAYS"
                        style="
                            -fx-background-color: #F0C667;
                            -fx-background-radius: 12;
                            -fx-text-fill: #232323;
                            -fx-font-size: 15px;
                            -fx-font-weight: bold;
                        "/>
            </HBox>

        </VBox>
    </right>

</BorderPane>
