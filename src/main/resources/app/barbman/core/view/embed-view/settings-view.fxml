<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.barbman.core.controller.SettingsController"
            styleClass="settings-root">

    <!-- TOP - HEADER -->
    <top>
        <VBox styleClass="settings-header">
            <padding>
                <Insets top="20" right="24" bottom="16" left="24"/>
            </padding>
            <Label text="Configuracion" styleClass="settings-title"/>
        </VBox>
    </top>

    <!-- CENTER - TABS -->
    <center>
        <TabPane fx:id="settingsTabPane"
                 tabClosingPolicy="UNAVAILABLE"
                 styleClass="settings-tabpane">

            <!-- ========================================= -->
            <!-- TAB: PRODUCTOS -->
            <!-- ========================================= -->
            <Tab text="Productos">
                <content>
                    <ScrollPane fitToWidth="true"
                                fitToHeight="true"
                                styleClass="settings-scrollpane">
                        <content>
                            <VBox spacing="20" styleClass="settings-tab-content">
                                <padding>
                                    <Insets top="24" right="24" bottom="24" left="24"/>
                                </padding>

                                <!-- Header con boton -->
                                <HBox alignment="CENTER_LEFT" spacing="16">
                                    <Label text="Gestion de Productos" styleClass="settings-section-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button text="+ Agregar Producto"
                                            styleClass="settings-btn-add"
                                            onAction="#onAddProduct"/>
                                </HBox>

                                <!-- FORMULARIO DE PRODUCTO -->
                                <VBox fx:id="productFormContainer"
                                      spacing="16"
                                      styleClass="settings-form"
                                      visible="false"
                                      managed="false">

                                    <Label fx:id="productFormTitle"
                                           text="Agregar Producto"
                                           styleClass="settings-form-title"/>

                                    <VBox spacing="8">
                                        <Label text="Nombre:" styleClass="settings-form-label"/>
                                        <TextField fx:id="productNameField"
                                                   promptText="Ej: Gel para cabello"
                                                   styleClass="settings-form-field"/>
                                    </VBox>

                                    <VBox spacing="8">
                                        <Label text="Precio de Costo:" styleClass="settings-form-label"/>
                                        <TextField fx:id="productCostField"
                                                   promptText="Ej: 30000"
                                                   styleClass="settings-form-field"/>
                                    </VBox>

                                    <VBox spacing="8">
                                        <Label text="Precio de Venta:" styleClass="settings-form-label"/>
                                        <TextField fx:id="productPriceField"
                                                   promptText="Ej: 50000"
                                                   styleClass="settings-form-field"/>
                                    </VBox>

                                    <VBox spacing="8">
                                        <Label text="Stock:" styleClass="settings-form-label"/>
                                        <TextField fx:id="productStockField"
                                                   promptText="Ej: 10"
                                                   styleClass="settings-form-field"/>
                                    </VBox>

                                    <HBox spacing="12" alignment="CENTER_RIGHT">
                                        <Button text="Cancelar"
                                                onAction="#onCancelProductForm"
                                                styleClass="settings-form-btn-cancel"/>
                                        <Button text="Guardar"
                                                onAction="#onSaveProduct"
                                                styleClass="settings-form-btn-save"/>
                                    </HBox>
                                </VBox>

                                <!-- LISTA DE PRODUCTOS -->
                                <VBox fx:id="productsListContainer"
                                      spacing="12"
                                      styleClass="settings-list">

                                    <Label text="Productos registrados:"
                                           styleClass="settings-list-title"/>

                                    <Label fx:id="productsEmptyLabel"
                                           text="No hay productos registrados"
                                           styleClass="settings-empty-message"
                                           visible="false"
                                           managed="false"/>
                                </VBox>

                            </VBox>
                        </content>
                    </ScrollPane>
                </content>
            </Tab>

            <!-- ========================================= -->
            <!-- TAB: SERVICIOS -->
            <!-- ========================================= -->
            <Tab text="Servicios">
                <content>
                    <ScrollPane fitToWidth="true"
                                fitToHeight="true"
                                styleClass="settings-scrollpane">
                        <content>
                            <VBox spacing="20" styleClass="settings-tab-content">
                                <padding>
                                    <Insets top="24" right="24" bottom="24" left="24"/>
                                </padding>

                                <!-- Header con boton -->
                                <HBox alignment="CENTER_LEFT" spacing="16">
                                    <Label text="Gestion de Servicios" styleClass="settings-section-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button text="+ Agregar Servicio"
                                            styleClass="settings-btn-add"
                                            onAction="#onAddService"/>
                                </HBox>

                                <!-- FORMULARIO DE SERVICIO -->
                                <VBox fx:id="serviceFormContainer"
                                      spacing="16"
                                      styleClass="settings-form"
                                      visible="false"
                                      managed="false">

                                    <Label fx:id="serviceFormTitle"
                                           text="Agregar Servicio"
                                           styleClass="settings-form-title"/>

                                    <VBox spacing="8">
                                        <Label text="Nombre:" styleClass="settings-form-label"/>
                                        <TextField fx:id="serviceNameField"
                                                   promptText="Ej: Corte de cabello"
                                                   styleClass="settings-form-field"/>
                                    </VBox>

                                    <VBox spacing="8">
                                        <Label text="Precio Base:" styleClass="settings-form-label"/>
                                        <TextField fx:id="servicePriceField"
                                                   promptText="Ej: 50000"
                                                   styleClass="settings-form-field"/>
                                    </VBox>

                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <CheckBox fx:id="serviceAvailableCheckbox"
                                                  text="Disponible"
                                                  selected="true"
                                                  styleClass="settings-form-checkbox"/>
                                    </HBox>

                                    <HBox spacing="12" alignment="CENTER_RIGHT">
                                        <Button text="Cancelar"
                                                onAction="#onCancelServiceForm"
                                                styleClass="settings-form-btn-cancel"/>
                                        <Button text="Guardar"
                                                onAction="#onSaveService"
                                                styleClass="settings-form-btn-save"/>
                                    </HBox>
                                </VBox>

                                <!-- Lista de servicios -->
                                <VBox fx:id="servicesListContainer"
                                      spacing="12"
                                      styleClass="settings-list">

                                    <Label text="Servicios registrados:"
                                           styleClass="settings-list-title"/>

                                    <Label fx:id="servicesEmptyLabel"
                                           text="No hay servicios registrados"
                                           styleClass="settings-empty-message"
                                           visible="false"
                                           managed="false"/>
                                </VBox>

                            </VBox>
                        </content>
                    </ScrollPane>
                </content>
            </Tab>

            <!-- ========================================= -->
            <!-- TAB: USUARIOS -->
            <!-- ========================================= -->
            <Tab text="Usuarios">
                <content>
                    <ScrollPane fitToWidth="true"
                                fitToHeight="true"
                                styleClass="settings-scrollpane">
                        <content>
                            <VBox spacing="20" styleClass="settings-tab-content">
                                <padding>
                                    <Insets top="24" right="24" bottom="24" left="24"/>
                                </padding>

                                <!-- Header con boton -->
                                <HBox alignment="CENTER_LEFT" spacing="16">
                                    <Label text="Gestion de Usuarios" styleClass="settings-section-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button text="+ Agregar Usuario"
                                            styleClass="settings-btn-add"
                                            onAction="#onAddUser"/>
                                </HBox>

                                <!-- FORMULARIO DE USUARIO -->
                                <VBox fx:id="userFormContainer"
                                      spacing="16"
                                      styleClass="settings-form"
                                      visible="false"
                                      managed="false">

                                    <Label fx:id="userFormTitle"
                                           text="Agregar Usuario"
                                           styleClass="settings-form-title"/>

                                    <VBox spacing="8">
                                        <Label text="Nombre:" styleClass="settings-form-label"/>
                                        <TextField fx:id="userNameField"
                                                   promptText="Ej: Maria Lopez"
                                                   styleClass="settings-form-field"/>
                                    </VBox>

                                    <VBox spacing="8">
                                        <Label text="PIN (4 digitos):" styleClass="settings-form-label"/>
                                        <TextField fx:id="userPinField"
                                                   promptText="Ej: 1234"
                                                   styleClass="settings-form-field"
                                                   maxWidth="150"/>
                                    </VBox>

                                    <VBox spacing="8">
                                        <Label text="Rol:" styleClass="settings-form-label"/>
                                        <ComboBox fx:id="userRoleCombo"
                                                  styleClass="settings-form-combo"
                                                  prefWidth="200"/>
                                    </VBox>

                                    <HBox spacing="12" alignment="CENTER_RIGHT">
                                        <Button text="Cancelar"
                                                onAction="#onCancelUserForm"
                                                styleClass="settings-form-btn-cancel"/>
                                        <Button text="Guardar"
                                                onAction="#onSaveUser"
                                                styleClass="settings-form-btn-save"/>
                                    </HBox>
                                </VBox>

                                <!-- Lista de usuarios -->
                                <VBox fx:id="usersListContainer"
                                      spacing="12"
                                      styleClass="settings-list">

                                    <Label text="Usuarios registrados:"
                                           styleClass="settings-list-title"/>

                                    <Label fx:id="usersEmptyLabel"
                                           text="No hay usuarios registrados"
                                           styleClass="settings-empty-message"
                                           visible="false"
                                           managed="false"/>
                                </VBox>

                            </VBox>
                        </content>
                    </ScrollPane>
                </content>
            </Tab>

            <!-- ========================================= -->
            <!-- TAB: CLIENTES -->
            <!-- ========================================= -->
            <Tab text="Clientes">
                <content>
                    <ScrollPane fitToWidth="true"
                                fitToHeight="true"
                                styleClass="settings-scrollpane">
                        <content>
                            <VBox spacing="20" styleClass="settings-tab-content">
                                <padding>
                                    <Insets top="24" right="24" bottom="24" left="24"/>
                                </padding>

                                <!-- Header con boton -->
                                <HBox alignment="CENTER_LEFT" spacing="16">
                                    <Label text="Gestion de Clientes" styleClass="settings-section-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button text="+ Agregar Cliente"
                                            styleClass="settings-btn-add"
                                            onAction="#onAddClient"/>
                                </HBox>

                                <!-- FORMULARIO DE CLIENTE -->
                                <VBox fx:id="clientFormContainer"
                                      spacing="16"
                                      styleClass="settings-form"
                                      visible="false"
                                      managed="false">

                                    <Label fx:id="clientFormTitle"
                                           text="Agregar Cliente"
                                           styleClass="settings-form-title"/>

                                    <VBox spacing="8">
                                        <Label text="Nombre: *" styleClass="settings-form-label"/>
                                        <TextField fx:id="clientNameField"
                                                   promptText="Ej: Juan Perez"
                                                   styleClass="settings-form-field"/>
                                    </VBox>

                                    <VBox spacing="8">
                                        <Label text="Telefono:" styleClass="settings-form-label"/>
                                        <TextField fx:id="clientPhoneField"
                                                   promptText="Ej: 0981-123456"
                                                   styleClass="settings-form-field"/>
                                    </VBox>

                                    <VBox spacing="8">
                                        <Label text="Email:" styleClass="settings-form-label"/>
                                        <TextField fx:id="clientEmailField"
                                                   promptText="Ej: cliente@example.com"
                                                   styleClass="settings-form-field"/>
                                    </VBox>

                                    <VBox spacing="8">
                                        <Label text="Documento/RUC:" styleClass="settings-form-label"/>
                                        <TextField fx:id="clientDocumentField"
                                                   promptText="Ej: 12345678-9"
                                                   styleClass="settings-form-field"/>
                                    </VBox>

                                    <VBox spacing="8">
                                        <Label text="Notas:" styleClass="settings-form-label"/>
                                        <TextArea fx:id="clientNotesField"
                                                  promptText="Observaciones adicionales"
                                                  styleClass="settings-form-field"
                                                  prefRowCount="3"/>
                                    </VBox>
                                    <HBox spacing="8" alignment="CENTER_LEFT">
                                        <CheckBox fx:id="clientActiveCheckbox"
                                                  text="Cliente activo"
                                                  selected="true"
                                                  styleClass="settings-form-checkbox"/>
                                    </HBox>

                                    <HBox spacing="12" alignment="CENTER_RIGHT">
                                        <Button text="Cancelar"
                                                onAction="#onCancelClientForm"
                                                styleClass="settings-form-btn-cancel"/>
                                        <Button text="Guardar"
                                                onAction="#onSaveClient"
                                                styleClass="settings-form-btn-save"/>
                                    </HBox>
                                </VBox>

                                <!-- Lista de clientes -->
                                <VBox fx:id="clientsListContainer"
                                      spacing="12"
                                      styleClass="settings-list">

                                    <Label text="Clientes registrados:"
                                           styleClass="settings-list-title"/>

                                    <Label fx:id="clientsEmptyLabel"
                                           text="No hay clientes registrados"
                                           styleClass="settings-empty-message"
                                           visible="false"
                                           managed="false"/>
                                </VBox>

                            </VBox>
                        </content>
                    </ScrollPane>
                </content>
            </Tab>

        </TabPane>
    </center>

</BorderPane>